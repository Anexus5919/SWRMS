# Vercel build skips these — keeps the deploy artifact lean.
# Seed scripts run against the database directly from a developer's
# machine; they don't need to be inside the Lambda runtime.
seed/

# Local-only env files (Vercel uses its own env-var management)
.env.local
.env*.local

# Build artefacts and caches that Vercel rebuilds on its own
.next/
node_modules/

# Editor + OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
